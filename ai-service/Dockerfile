# ============================================================
# Stage 1: Builder — install all Python dependencies
# Uses slim base with build tools, discarded after this stage
# ============================================================
FROM python:3.11-slim AS builder

WORKDIR /install

# Install system build deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ libglib2.0-0 libgl1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Install CPU-only torch from the official PyTorch index (much smaller than default)
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        torch torchvision --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir \
        fastapi==0.111.0 \
        uvicorn[standard]==0.29.0 \
        python-dotenv==1.0.1 \
        requests==2.32.2 \
        numpy==1.26.4 \
        Pillow==10.3.0 \
        opencv-python-headless==4.9.0.80

# ============================================================
# Stage 2: Runtime — lean final image
# Only copies installed site-packages, not build tools
# ============================================================
FROM python:3.11-slim AS runtime

WORKDIR /app

# Runtime system libs only (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 libgl1 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder stage
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application source
COPY app.py .

# Copy pre-trained A2C weights (generated by running: python train_a2c.py)
# If the file doesn't exist, app falls back to Haversine heuristic automatically
COPY a2c_weights.pth* ./

EXPOSE 9000

CMD ["python", "-m", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "9000", "--workers", "1"]
