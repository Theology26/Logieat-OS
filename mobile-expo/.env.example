# LogiEat OS — mobile (Expo) environment.
# Copy to .env. EXPO_PUBLIC_* vars are embedded in the JS bundle (also baked into the APK).
#
# Pick the base URL that matches HOW you run the app (see docs/API.md §1):
#   Android emulator ........ http://10.0.2.2:8001
#   Real device / APK ....... http://<YOUR-PC-LAN-IP>:8001   (e.g. http://192.168.1.10:8001)
#   ngrok (anywhere) ........ https://xxxx.ngrok-free.app
#   production .............. https://api.yourdomain.com

EXPO_PUBLIC_API_URL=http://10.0.2.2:8001/api
EXPO_PUBLIC_CORE_URL=http://10.0.2.2:8080
EXPO_PUBLIC_WS_URL=ws://10.0.2.2:8080/ws
