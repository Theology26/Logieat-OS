{
  "expo": {
    "name": "LogiEat Kurir",
    "slug": "logieat-kurir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.logieat.kurir",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "Izinkan akses kamera untuk bukti pengantaran (PoD)." }],
      ["expo-location", { "locationWhenInUsePermission": "Izinkan lokasi untuk navigasi & pelacakan pengantaran." }],
      ["expo-notifications", { "color": "#5264AE" }],
      ["expo-build-properties", { "android": { "usesCleartextTraffic": true } }]
    ]
  }
}
