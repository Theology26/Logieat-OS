# LogiEat OS — Go core service
PORT=8080
# MySQL DSN (shared DB with Laravel — Laragon default root has no password)
DB_DSN=root:@tcp(127.0.0.1:3306)/logieat?parseTime=true&loc=UTC
REDIS_URL=redis://127.0.0.1:6379
AI_SERVICE_URL=http://127.0.0.1:9000
OSRM_URL=http://127.0.0.1:5000
# MUST match Laravel's JWT secret
JWT_SECRET=change-me-shared-with-laravel
